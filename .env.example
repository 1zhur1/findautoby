# URL бэкенда. Локально — прямой адрес; в проде — относительный /api (см. .env.production),
# который nginx проксирует на бэкенд.
VITE_API_URL=http://localhost:4245/api

# Имя бота из BotFather (без @) — используется для ссылок
VITE_TELEGRAM_BOT_NAME=FindAutoBot

VITE_APP_ENV=development

# ВНИМАНИЕ: токен бота НЕ должен храниться во фронтенде.
# Любая переменная VITE_* попадает в клиентский бандл и видна всем.
# Токен используется только на сервере/боте.
