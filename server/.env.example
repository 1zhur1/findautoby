# Порт API
PORT=8000

# Токен бота из @BotFather — ОБЯЗАТЕЛЕН для валидации initData в проде.
# Храните его ТОЛЬКО здесь, на сервере. Никогда не кладите в фронтенд.
TELEGRAM_BOT_TOKEN=

# Разрешить вход без валидного initData (для локальной разработки без Telegram).
# В проде ДОЛЖНО быть false.
ALLOW_INSECURE_AUTH=true

# Максимальный возраст initData в секундах (защита от повторного использования)
INIT_DATA_MAX_AGE_SEC=86400

# Разрешённые Origin для CORS (через запятую). * — любой.
CORS_ORIGIN=*

# Путь к файлу базы SQLite
DATABASE_PATH=./data/findauto.db

# --- Парсинг av.by через headless-браузер (обход SafeLine WAF) ---
# av.by защищён антиботом SafeLine, обычным HTTP-клиентом не парсится.
# Требует patchright + браузер: npx patchright install chromium (на Ubuntu — --with-deps).
# Onliner и Kufar работают без этого. Включайте только после проверки verify-avby.mjs на сервере.
AVBY_ENABLED=false
# Запуск браузера в headful-режиме (для отладки через xvfb-run)
AVBY_HEADFUL=false
